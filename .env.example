# PayPay OPA (Open Payment API) credentials — get these from https://developer.paypay.ne.jp/
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

PAYPAY_API_KEY=your-api-key-id
PAYPAY_API_SECRET=your-api-key-secret
PAYPAY_MERCHANT_ID=your-merchant-id

# Environment: "sandbox" (testing) or "production" (live money — be careful)
PAYPAY_ENV=sandbox

# ------------------------------------------------------------------------
# MCP transport. "stdio" (default) for local clients (Claude Desktop, Cursor, etc.)
# or "http" for remote hosting (Glama, Smithery, ChatGPT Apps SDK, your own infra).
# ------------------------------------------------------------------------
MCP_TRANSPORT=stdio

# Only used when MCP_TRANSPORT=http:
MCP_HTTP_PORT=3000
# Default 127.0.0.1. You can set 0.0.0.0 behind your own TLS/reverse proxy.
MCP_HTTP_HOST=127.0.0.1
# Strong random string. Required whenever MCP_TRANSPORT=http.
# Clients must send `Authorization: Bearer <token>`.
# MCP_AUTH_TOKEN=
# Comma-separated CORS origin allowlist. Default: no cross-origin access.
# MCP_HTTP_ALLOWED_ORIGINS=https://app.example.com,https://claude.ai
